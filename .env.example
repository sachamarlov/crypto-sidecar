# =============================================================================
# GuardiaBox — example environment file
# Copy to `.env` and customise. `.env` is gitignored by default.
# All variables are read by `pydantic-settings` via the `GUARDIABOX_` prefix.
# =============================================================================

# Where the SQLCipher DB and per-user keystores live (default: ~/.guardiabox).
GUARDIABOX_DATA_DIR=

# Auto-lock after N minutes of inactivity (default: 15, range: 1..240).
GUARDIABOX_AUTO_LOCK_MINUTES=15

# --- Cryptography (overridable, but the floor is hardcoded) -----------------

# PBKDF2-HMAC-SHA256 iterations (minimum 600 000 — OWASP FIPS-140 2026).
GUARDIABOX_CRYPTO__PBKDF2_ITERATIONS=600000

# Argon2id parameters (m=64 MiB t=3 p=1 — OWASP 2026).
GUARDIABOX_CRYPTO__ARGON2ID_MEMORY_COST_KIB=65536
GUARDIABOX_CRYPTO__ARGON2ID_TIME_COST=3
GUARDIABOX_CRYPTO__ARGON2ID_PARALLELISM=1

# RSA modulus length for hybrid sharing (3072 or 4096 only).
GUARDIABOX_CRYPTO__RSA_KEY_BITS=4096

# --- Tauri sidecar HTTP server ---------------------------------------------

# Bind address — must remain 127.0.0.1.
GUARDIABOX_SIDECAR__HOST=127.0.0.1

# Port (0 = auto-pick a free one). The Tauri shell parses the actual port
# from the sidecar's first stdout line.
GUARDIABOX_SIDECAR__PORT=0

# Log verbosity for the sidecar (DEBUG/INFO/WARNING/ERROR).
GUARDIABOX_SIDECAR__LOG_LEVEL=INFO
