{
  "name": "guardiabox-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GuardiaBox — Tauri 2 frontend (React 19 + Vite + Tailwind v4 + shadcn).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsr generate && tsc -b && vite build",
    "preview": "vite preview",
    "routes:generate": "tsr generate",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsr generate && tsc --noEmit"
  },
  "dependencies": {
