{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Granular capability set for GuardiaBox. Per CLAUDE.md S11 + ADR-0016 sec G, NEVER use `<plugin>:default` bundles -- enumerate every verb the React layer actually invokes so the attack surface is auditable on every PR. Audit B P0-4 / C P0-2 enforced 2026-04-29.",
  "windows": ["main"],
  "permissions": [
    "core:app:allow-version",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-unlisten",
    "core:path:allow-resolve-directory",
    "core:path:allow-resolve",
    "core:webview:allow-internal-toggle-devtools",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unminimize",
    "core:window:allow-unmaximize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-is-minimized",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission"
  ]
}
